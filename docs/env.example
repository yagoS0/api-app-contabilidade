# Ambiente
NODE_ENV=development
LOG_LEVEL=info
TZ=America/Sao_Paulo

# Segurança (recomendado)
# Lista de chaves (separadas por vírgula) aceitas pelo backend
API_KEYS=chave-interna-1,chave-interna-2

# Autenticação com usuário/senha
# Usuário admin inicial (usado no script npm run prisma:seed)
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=trocar123
# Opcional
ADMIN_NAME=Administrador

# Fallback adicional: array JSON em AUTH_USERS (útil durante migração; pode remover após mover todos para o banco)
# Exemplo: [{"username":"admin","password":"mudar123","role":"admin"}]
AUTH_USERS=[]
JWT_SECRET=
# Opcional: padrão 1h
# JWT_EXPIRES_IN=1h
# Refresh token (opcional; padrão 7d)
# REFRESH_TOKEN_EXPIRES_IN=7d

# Storage (S3 ou compatível) para XML/PDF de notas
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Google Service Account
# Caminho absoluto para o JSON de credenciais
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
# Alternativa para ambientes PaaS: JSON inline em variável secreta
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# E-mail
# Use Gmail API (delegação) OU SMTP. Se USE_GMAIL_API=1, configure o usuário delegado.
# Gmail API: prioridade GOOGLE_APPLICATION_CREDENTIALS_JSON (recomendado no Railway); senão arquivo em GOOGLE_APPLICATION_CREDENTIALS (deve ser .json, não pasta).
USE_GMAIL_API=0
GMAIL_DELEGATED_USER=
# SMTP (fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Remetente; se vazio, usa GMAIL_DELEGATED_USER
SMTP_FROM=

# Servidor HTTP
HOST=0.0.0.0
PORT=3000

# Guias: PDFs ficam em PostgreSQL (Guide.pdfBytes). Upload pelo portal.
# Serviço FastAPI de extração de PDF (obrigatório para upload de guias). Ex. rede privada:
# PDF_READER_URL=http://pdf-reader.railway.internal:8000
# PDF_READER_TIMEOUT_MS=30000
# Opcional: fixa YYYY-MM para alertas de guia na lista de empresas (padrão = mês civil anterior).
# GUIDE_COMPLIANCE_COMPETENCIA=2026-02

# SERPRO / Integra Contador
# Habilita a base da integracao com PGDAS-D
# SERPRO_ENABLE_PGDASD=0
# SERPRO_ENV=homolog
# SERPRO_AUTH_URL=https://autenticacao.sapi.serpro.gov.br/authenticate
# SERPRO_BASE_URL=https://gateway.apiserpro.serpro.gov.br/integra-contador/v1
# SERPRO_CONSUMER_KEY=
# SERPRO_CONSUMER_SECRET=
# SERPRO_SCOPE=
# SERPRO_TIMEOUT_MS=30000
# Company legada que armazena o PFX/P12 do escritorio/procurador
# SERPRO_CERT_COMPANY_ID=
# SERPRO_PGDASD_WORKER_ENABLED=0

# NFS-e (padrão nacional)
NFSE_CERT_PFX_PATH=/abs/path/to/certificado.pfx
NFSE_CERT_PFX_PASSWORD=senha-certificado
# Base do provedor (ex.: SEFIN Nacional)
NFSE_BASE_URL=https://sefin.nfse.gov.br/SefinNacional
# NFSE_ENV=homolog
# NFSE_PATH=/nfse          # emissão via DPS
# NFSE_CONSULT_PATH=/nfse/consulta  # consulta por período (XML)
# NFSE_DPS_PATH=/dps       # consulta por idDps
# NFSE_NFSE_PATH=/nfse     # consulta por chaveAcesso

# ADN (Ambiente Nacional de Dados)
# ADN_BASE_URL=https://adn.nfse.gov.br/contribuintes
# ADN_DFE_PATH=/DFe  # mantenha o DFe com maiúsculas
# ADN_CNPJ_CONSULTA=12345678000199
# ADN_CERT_PATH=./cert.pem
# ADN_KEY_PATH=./key.pem
# NFSE_BASE_URL=https://api.nacional.nfse.gov.br
