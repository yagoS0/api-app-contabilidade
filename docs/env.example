# Ambiente
NODE_ENV=development
LOG_LEVEL=info
TZ=America/Sao_Paulo

# Segurança (recomendado)
# Lista de chaves (separadas por vírgula) aceitas pelo backend
API_KEYS=chave-interna-1,chave-interna-2

# Autenticação com usuário/senha
# Usuário admin inicial (usado no script npm run prisma:seed)
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=trocar123
# Opcional
ADMIN_NAME=Administrador

# Fallback adicional: array JSON em AUTH_USERS (útil durante migração; pode remover após mover todos para o banco)
# Exemplo: [{"username":"admin","password":"mudar123","role":"admin"}]
AUTH_USERS=[]
JWT_SECRET=
# Opcional: padrão 1h
# JWT_EXPIRES_IN=1h
# Refresh token (opcional; padrão 7d)
# REFRESH_TOKEN_EXPIRES_IN=7d

# Storage (S3 ou compatível) para XML/PDF de notas
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Google Service Account
# Caminho absoluto para o JSON de credenciais
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Drive
# Raiz onde ficam as pastas dos clientes (já existente)
DRIVE_FOLDER_ID_CLIENTES=1UilHh0ivRAGQX8YjSQ7fkJMUt231llAY
# Google Sheets
# ID da planilha com colunas: A=Cliente, B=Email (sem cabeçalho)
SHEET_ID=
# (opcionais para leituras mais flexíveis)
# SHEET_TAB=NomeDaAba
# SHEET_RANGE=A:B
# SHEET_HAS_HEADER=0
# SHEET_START_ROW=1

# E-mail
# Use Gmail API (delegação) OU SMTP. Se USE_GMAIL_API=1, configure o usuário delegado.
USE_GMAIL_API=0
GMAIL_DELEGATED_USER=
# SMTP (fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Remetente; se vazio, usa GMAIL_DELEGATED_USER
SMTP_FROM=

# Execução
# Envio de guias: força reenvio mesmo marcados como processados
# FORCE_SEND=1
# Alvo de mês (envio de guias): "MM-AAAA" (se vazio, usa lógica padrão)
# TARGET_MONTH=

# Servidor HTTP
HOST=0.0.0.0
PORT=3000

# CRON (opcional, ex.: todos os dias úteis às 08:00)
# CRON_SCHEDULE=0 8 * * 1-5

# NFS-e (padrão nacional)
NFSE_CERT_PFX_PATH=/abs/path/to/certificado.pfx
NFSE_CERT_PFX_PASSWORD=senha-certificado
# Base do provedor (ex.: SEFIN Nacional)
NFSE_BASE_URL=https://sefin.nfse.gov.br/SefinNacional
# NFSE_ENV=homolog
# NFSE_PATH=/nfse          # emissão via DPS
# NFSE_CONSULT_PATH=/nfse/consulta  # consulta por período (XML)
# NFSE_DPS_PATH=/dps       # consulta por idDps
# NFSE_NFSE_PATH=/nfse     # consulta por chaveAcesso

# ADN (Ambiente Nacional de Dados)
# ADN_BASE_URL=https://adn.nfse.gov.br/contribuintes
# ADN_DFE_PATH=/DFe  # mantenha o DFe com maiúsculas
# ADN_CNPJ_CONSULTA=12345678000199
# ADN_CERT_PATH=./cert.pem
# ADN_KEY_PATH=./key.pem
# ADN_SYNC_CRON=*/15 * * * *  # opcional: sincroniza a cada 15 minutos
// NFSE_BASE_URL=https://api.nacional.nfse.gov.br