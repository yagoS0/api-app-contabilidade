@baseUrl = http://localhost:3000

# IMPORTANTE
# - Se /auth/login estiver retornando {"error":"internal_error"}, quase sempre é Postgres parado.
#   Verifique: `ss -lptn 'sport = :5432'` e suba o banco antes de testar as rotas.
#
# Se o seu Cursor não suportar variáveis `@baseUrl`/`{{accessToken}}`, use as requests
# marcadas como "SEM_VARIAVEIS" (URLs e headers fixos) e substitua manualmente.

# Cole seus valores aqui (depois do login)
@accessToken = REPLACE_ME
@refreshToken = REPLACE_ME

# PortalClient.id (retorna em GET /clients)
@portalClientId = REPLACE_ME

# PortalInvoice.id (retorna em GET /clients/:clientId/invoices)
@portalInvoiceId = REPLACE_ME

# Sync job id (retorna em POST /clients/:clientId/invoices/sync/start)
@syncJobId = REPLACE_ME

# Guide.id (retorna em listagens de guides)
@guideId = REPLACE_ME

###############################################################################
# AUTH
###############################################################################

### Healthz OK
GET {{baseUrl}}/healthz

### Auth OK  - Login (admin/contador/user OR cliente)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "yago@belgencontabilidade.com",
  "password": "1408120600"
}

### SEM_VARIAVEIS - Auth Login OK
POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "email": "yago@belgencontabilidade.com",
  "password": "1408120600"
}

### Auth - Refresh token OK
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Auth - Me OK
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

###############################################################################
# PORTAL: CLIENTS
###############################################################################

### Portal - List clients (companies) OK
GET {{baseUrl}}/clients?page=1&limit=20&search=
Authorization: Bearer {{accessToken}}

### Portal - Get client OK
GET {{baseUrl}}/clients/{{portalClientId}}
Authorization: Bearer {{accessToken}}

### Portal - Get integration settings OK
GET {{baseUrl}}/clients/{{portalClientId}}/integration-settings
Authorization: Bearer {{accessToken}}

### Portal - Patch integration settings
PATCH {{baseUrl}}/clients/{{portalClientId}}/integration-settings
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "provider": "NFSENACIONAL",
  "environment": "PROD"
}

###############################################################################
# PORTAL: INVOICES (lista + filtros)
###############################################################################

### Portal - List invoices (default sort: updatedAt desc) OK
GET {{baseUrl}}/clients/{{portalClientId}}/invoices?page=1&limit=25&sort=updatedAt&order=desc
Authorization: Bearer {{accessToken}}

### Portal - List invoices (filters examples) ok
GET {{baseUrl}}/clients/{{portalClientId}}/invoices?competencia=2026-02&status=CANCELADA&type=NFSE&search=&page=1&limit=25&sort=updatedAt&order=desc
Authorization: Bearer {{accessToken}}

### Portal - Invoice detailc OK
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/{{portalInvoiceId}}
Authorization: Bearer {{accessToken}}

###############################################################################
# PORTAL: XML / PDF / EVENTS
###############################################################################

### Portal - Download XML (attachment)
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/{{portalInvoiceId}}/xml
Authorization: Bearer {{accessToken}}

### Portal - Download XML bulk ZIP (by filters)
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/xml/bulk?competencia=2026-02&direcao=emitidas&limit=1000
Authorization: Bearer {{accessToken}}

### Portal - Get XML raw JSON
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/{{portalInvoiceId}}/xml/raw
Authorization: Bearer {{accessToken}}

### Portal - Reparse XML (update derived fields)
POST {{baseUrl}}/clients/{{portalClientId}}/invoices/{{portalInvoiceId}}/reparse
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Portal - PDF (MVP: redirect to pdfUrl if exists)
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/{{portalInvoiceId}}/pdf
Authorization: Bearer {{accessToken}}

### Portal - Events
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/{{portalInvoiceId}}/events
Authorization: Bearer {{accessToken}}

###############################################################################
# PORTAL: IMPORT XML (multipart)
###############################################################################

# Observação: arquivos .http nem sempre suportam multipart de forma consistente.
# Use o curl abaixo (substitua o path do arquivo):
#
# curl -X POST "{{baseUrl}}/clients/{{portalClientId}}/invoices/import/xml" \
#   -H "authorization: Bearer {{accessToken}}" \
#   -F "files=@/caminho/para/nota1.xml" \
#   -F "files=@/caminho/para/nota2.xml"

###############################################################################
# PORTAL: SYNC (lock/TTL/backoff)
###############################################################################

### Portal - Start sync (idempotent)
POST {{baseUrl}}/clients/{{portalClientId}}/invoices/sync/start
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Portal - Start FULL sync (reset cursor) - admin/contador
POST {{baseUrl}}/clients/{{portalClientId}}/invoices/sync/start
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "resetCursor": true,
  "maxIterations": 300
}

### Portal - Sync job status
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/sync/status/{{syncJobId}}
Authorization: Bearer {{accessToken}}

### Portal - Sync summary
GET {{baseUrl}}/clients/{{portalClientId}}/invoices/sync/summary
Authorization: Bearer {{accessToken}}

### Portal - Sync status for one invoice (MVP: based on stored events)
POST {{baseUrl}}/clients/{{portalClientId}}/invoices/sync/{{portalInvoiceId}}/sync-status
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

###############################################################################
# NOVO CADASTRO: PORTAL CLIENTE (/client/*)
###############################################################################

### Client portal - list companies for logged client
GET {{baseUrl}}/client/companies
Authorization: Bearer {{accessToken}}

### Client portal - list partners
GET {{baseUrl}}/client/companies/{{portalClientId}}/partners
Authorization: Bearer {{accessToken}}

### Client portal - create partner (OWNER/CLIENT_ADMIN)
POST {{baseUrl}}/client/companies/{{portalClientId}}/partners
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Socio Teste",
  "documento": "12345678901",
  "participacao": 10
}

### Client portal - list users in company
GET {{baseUrl}}/client/companies/{{portalClientId}}/users
Authorization: Bearer {{accessToken}}

### Client portal - invite user (OWNER/CLIENT_ADMIN)
POST {{baseUrl}}/client/companies/{{portalClientId}}/users/invite
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "novo.usuario@exemplo.com",
  "name": "Novo Usuario",
  "role": "CLIENT_USER"
}

### Client portal - invoices list via new prefix
GET {{baseUrl}}/client/companies/{{portalClientId}}/invoices?page=1&limit=25
Authorization: Bearer {{accessToken}}

### Client portal - start sync via new prefix
POST {{baseUrl}}/client/companies/{{portalClientId}}/invoices/sync/start
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Client portal - certificate status ok
GET {{baseUrl}}/client/companies/{{portalClientId}}/certificate
Authorization: Bearer {{accessToken}}

# multipart example: ok
# curl -X POST "{{baseUrl}}/client/companies/{{portalClientId}}/certificate" \
#   -H "authorization: Bearer {{accessToken}}" \
#   -F "pfx=@/caminho/certificado.pfx" \
#   -F "password=SEU_SEGREDO"

### Client portal - delete certificate
DELETE {{baseUrl}}/client/companies/{{portalClientId}}/certificate
Authorization: Bearer {{accessToken}}

### Client portal - list guides by competencia/status
GET {{baseUrl}}/client/companies/{{portalClientId}}/guides?competencia=2026-02&status=PROCESSED&page=1&limit=25
Authorization: Bearer {{accessToken}}

### Client portal - download guide (signed/local URL)
GET {{baseUrl}}/client/companies/{{portalClientId}}/guides/{{guideId}}/download
Authorization: Bearer {{accessToken}}

###############################################################################
# NOVO CADASTRO: PORTAL ESCRITÓRIO (/firm/*)
###############################################################################

### Firm portal - list company wallet ok
GET {{baseUrl}}/firm/companies
Authorization: Bearer {{accessToken}}

### Firm portal - create company + owner link + firm link ok
POST {{baseUrl}}/firm/companies
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "ownerEmail": "owner.empresa@exemplo.com",
  "ownerName": "Owner Empresa",
  "ownerPassword": "SenhaForte123",
  "company": {
    "cnpj": "12345678000199",
    "razaoSocial": "EMPRESA TESTE LTDA",
    "nomeFantasia": "Empresa Teste",
    "regimeTributario": "SIMPLES",
    "simples": {
      "anexo": "III",
      "dataOpcao": "2024-01-01"
    },
    "cnaePrincipal": "6201-5/01",
    "cnaesSecundarios": ["6311-9/00"],
    "endereco": {
      "rua": "Rua Alto Alegre",
      "numero": "323",
      "complemento": "Casa 1",
      "bairro": "Pechincha",
      "cidade": "Rio de Janeiro",
      "uf": "RJ",
      "cep": "22770001"
    }
  }
}

### Firm portal - grant office access to company
POST {{baseUrl}}/firm/companies/{{portalClientId}}/access
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "userId": "REPLACE_FIRM_USER_ID",
  "role": "ACCOUNTANT",
  "scopes": ["NOTES", "GUIDES"]
}

### Firm portal - invoices list via new prefix  
GET {{baseUrl}}/firm/companies/{{portalClientId}}/invoices?page=1&limit=25
Authorization: Bearer {{accessToken}}

### Firm portal - certificate status ok 
GET {{baseUrl}}/firm/companies/{{portalClientId}}/certificate
Authorization: Bearer {{accessToken}}

# multipart example:
# curl -X POST "{{baseUrl}}/firm/companies/{{portalClientId}}/certificate" \
#   -H "authorization: Bearer {{accessToken}}" \
#   -F "pfx=@/caminho/certificado.pfx" \
#   -F "password=SEU_SEGREDO"

### Firm portal - delete certificate ok
DELETE {{baseUrl}}/firm/companies/{{portalClientId}}/certificate
Authorization: Bearer {{accessToken}}

### Firm portal - list guides by company
GET {{baseUrl}}/firm/companies/{{portalClientId}}/guides?competencia=2026-02&status=PROCESSED&page=1&limit=25
Authorization: Bearer {{accessToken}}

### Firm portal - download guide by company
GET {{baseUrl}}/firm/companies/{{portalClientId}}/guides/{{guideId}}/download
Authorization: Bearer {{accessToken}}

### Firm portal - run inbox ingestion once (button action)
POST {{baseUrl}}/firm/guides/ingestion/run
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "batchSize": 25,
  "maxDurationMs": 25000
}

### Dev (admin only) - resetar hashes de guias
POST {{baseUrl}}/firm/dev/guides/reset-hash
Authorization: Bearer {{accessToken}}

### Firm portal - get guides runtime settings (Drive; pdfReaderConfigured vem do PDF_READER_URL na API)
GET {{baseUrl}}/firm/guides/settings
Authorization: Bearer {{accessToken}}

### Firm portal - update guides runtime settings (inbox + pasta de saída; subpastas criadas automaticamente)
PATCH {{baseUrl}}/firm/guides/settings
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "guideScheduleCron": "0 12 * * *"
}

### Firm portal - manual assign guide and finalize
POST {{baseUrl}}/firm/guides/{{guideId}}/manual-assign
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "companyId": "{{portalClientId}}",
  "competencia": "2026-02",
  "tipo": "SIMPLES"
}

### Firm portal - reenviar e-mail da guia (coloca na fila; worker envia no próximo ciclo)
POST {{baseUrl}}/firm/guides/{{guideId}}/resend-email
Authorization: Bearer {{accessToken}}

### Firm portal - enviar guias da empresa (competência mais recente; não reenvia já enviadas)
POST {{baseUrl}}/firm/companies/{{portalClientId}}/guides/send-email-latest
Authorization: Bearer {{accessToken}}

### Firm portal - definir agenda de envio da empresa (ex.: dias 3 e 13)
PATCH {{baseUrl}}/firm/companies/{{portalClientId}}/email-schedule
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "days": [3, 13]
}

### Firm portal - consultar agenda de envio da empresa
GET {{baseUrl}}/firm/companies/{{portalClientId}}/email-schedule
Authorization: Bearer {{accessToken}}

### Firm portal - executar envio agendado (dia atual)
POST {{baseUrl}}/firm/guides/emails/run-scheduled
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "maxFilesPerCompany": 15
}

### Firm portal - executar envio agendado forçando um dia específico
POST {{baseUrl}}/firm/guides/emails/run-scheduled
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "day": 13,
  "maxFilesPerCompany": 15
}

### Firm portal - simular envio agendado (dry-run)
POST {{baseUrl}}/firm/guides/emails/run-scheduled?dryRun=1
Authorization: Bearer {{accessToken}}

### Firm portal - enviar todos os e-mails PENDING/ERROR elegíveis agora
POST {{baseUrl}}/firm/guides/emails/send-pending
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "batchSize": 50,
  "maxBatches": 50
}

###############################################################################
# GUIDES - FLUXO RÁPIDO (Drive + Parser + Ingestão + Envio por Empresa)
###############################################################################

### Guides step 1 - salvar configuração runtime (só 2 IDs: inbox + pasta de saída; subpastas são criadas automaticamente)
PATCH {{baseUrl}}/firm/guides/settings
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "guideScheduleCron": "0 12 * * *"
}

### Guides step 2 - conferir configuração salva
GET {{baseUrl}}/firm/guides/settings
Authorization: Bearer {{accessToken}}

### Guides step 3 - rodar 1 ciclo de ingestão (botão do front)
POST {{baseUrl}}/firm/guides/ingestion/run
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "batchSize": 25,
  "maxDurationMs": 25000
}

### Guides step 4 - enviar e-mail da competência mais recente (anexos por empresa)
POST {{baseUrl}}/firm/companies/{{portalClientId}}/guides/send-email-latest
Authorization: Bearer {{accessToken}}

### Guides step 5 - chamar novamente (não deve reenviar as mesmas guias)
POST {{baseUrl}}/firm/companies/{{portalClientId}}/guides/send-email-latest
Authorization: Bearer {{accessToken}}

### Guides step 6 - após adicionar nova guia na mesma pasta, enviar novamente (envia só as novas)
POST {{baseUrl}}/firm/companies/{{portalClientId}}/guides/send-email-latest
Authorization: Bearer {{accessToken}}

### Guides step 7 - listagem final no contador por empresa
GET {{baseUrl}}/firm/companies/{{portalClientId}}/guides?competencia=2026-02&status=PROCESSED&page=1&limit=25
Authorization: Bearer {{accessToken}}

###############################################################################
# ADMIN (usuários do sistema)
###############################################################################

### Admin - List users (admin only)
GET {{baseUrl}}/admin/users?status=pending
Authorization: Bearer {{accessToken}}

###############################################################################
# LEGADO / API (ADN endpoints antigos ainda existentes)
###############################################################################

### Legacy ADN - Sync incremental
POST {{baseUrl}}/api/nfse/sync
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "companyId": "REPLACE_ME",
  "loop": true,
  "maxIterations": 10
}

### Legacy ADN - Force sync (admin only) + reset NSU
POST {{baseUrl}}/api/nfse/sync/force
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "companyId": "REPLACE_ME",
  "resetNsu": true,
  "maxIterations": 10
}

### Legacy ADN - Query unified
GET {{baseUrl}}/api/nfse/unified?cnpj=REPLACE_ME&tipo=todas&inicio=2026-02-01&fim=2026-02-29&limit=50&offset=0
Authorization: Bearer {{accessToken}}

### Legacy ADN - Notas (keyset)
GET {{baseUrl}}/api/notas?cnpj=REPLACE_ME&direcao=todas&competencia=2026-02&status=AUTORIZADA&limit=50
Authorization: Bearer {{accessToken}}

### Legacy ADN - Reset all (admin only)
POST {{baseUrl}}/api/nfse/reset-all
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "confirm": "RESET_ALL_NFSE"
}

###############################################################################
# LEGADO /nfse (notas emitidas pelo sistema)
###############################################################################

### Legacy NFSe - List (system)
GET {{baseUrl}}/nfse?companyId=REPLACE_ME&limit=20&offset=0
Authorization: Bearer {{accessToken}}

