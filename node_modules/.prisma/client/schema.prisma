generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  login           String           @unique
  passwordHash    String
  phone           String?
  cpf             String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  companies       Company[]
  invoices        Invoice[]
  serviceInvoices ServiceInvoice[]
}

model Company {
  id                       String           @id @default(uuid())
  clientId                 String
  razaoSocial              String
  cnpj                     String           @unique
  nomeFantasia             String?
  regimeTributario         String?
  simplesAnexo             String?
  simplesDataOpcao         DateTime?
  cnaePrincipal            String?
  cnaesSecundarios         String[]         @default([])
  enderecoJson             Json?
  atividades               String[]
  porte                    String?
  tipoTributario           String?
  anexoSimples             String?
  endereco                 String?
  email                    String?
  telefone                 String?
  capitalSocial            Decimal?         @db.Decimal(18, 2)
  dataAbertura             DateTime?
  quantidadeSocios         Int?
  inscricaoMunicipal       String?
  codigoServicoNacional    String?
  codigoServicoMunicipal   String?
  rpsSerie                 String?
  rpsNumero                String?
  optanteSimples           Boolean?         @default(false)
  regimeEspecialTributacao String?
  // Certificado A1 por empresa (PFX) para integrações (ADN/NFSe/etc.)
  certStorageKey           String?
  certPasswordEnc          String?
  certExpiresAt            DateTime?
  certUploadedAt           DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  client                   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  partners                 Partner[]
  invoices                 Invoice[]
  serviceInvoices          ServiceInvoice[]
  guides                   Guide[]

  @@index([regimeTributario])
  @@index([cnaePrincipal])
}

model Partner {
  id            String   @id @default(uuid())
  companyId     String
  name          String
  phone         String?
  email         String?
  participacao  Decimal? @db.Decimal(5, 2)
  documento     String?
  representante Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  status       String   @default("pending")
  accountType  String   @default("CLIENT") // CLIENT | FIRM
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyClientUsers CompanyClientUser[]
  companyFirmAccess  CompanyFirmAccess[]
}

model Invoice {
  id            String        @id @default(uuid())
  companyId     String
  clientId      String?
  chave         String
  numero        String?
  serie         String?
  dhEmi         DateTime?
  emitCnpj      String?
  emitNome      String?
  destDoc       String?
  destNome      String?
  cfopPrincipal String?
  valorTotal    Decimal?      @db.Decimal(18, 2)
  valorProdutos Decimal?      @db.Decimal(18, 2)
  valorServicos Decimal?      @db.Decimal(18, 2)
  valorImpostos Decimal?      @db.Decimal(18, 2)
  valorIcms     Decimal?      @db.Decimal(18, 2)
  valorPis      Decimal?      @db.Decimal(18, 2)
  valorCofins   Decimal?      @db.Decimal(18, 2)
  valorIss      Decimal?      @db.Decimal(18, 2)
  status        String        @default("imported")
  fileKey       String?
  fileUrl       String?
  fileType      String        @default("xml")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items         InvoiceItem[]

  @@unique([companyId, chave])
  @@index([companyId])
  @@index([clientId])
}

model InvoiceItem {
  id             String   @id @default(uuid())
  invoiceId      String
  codigo         String?
  descricao      String?
  ncm            String?
  cfop           String?
  unidade        String?
  quantidade     Decimal? @db.Decimal(14, 4)
  valorUnitario  Decimal? @db.Decimal(18, 4)
  valorTotal     Decimal? @db.Decimal(18, 2)
  cstIcms        String?
  csosn          String?
  cstPis         String?
  cstCofins      String?
  aliquotaIcms   Decimal? @db.Decimal(6, 3)
  aliquotaPis    Decimal? @db.Decimal(6, 3)
  aliquotaCofins Decimal? @db.Decimal(6, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model ServiceInvoice {
  id                String    @id @default(uuid())
  companyId         String
  clientId          String?
  tomadorDoc        String
  tomadorNome       String
  valorServicos     Decimal   @db.Decimal(18, 2)
  aliquota          Decimal?  @db.Decimal(6, 3)
  issRetido         Boolean   @default(false)
  competencia       DateTime?
  idDps             String?
  chaveAcesso       String?
  numeroNfse        String?
  codigoVerificacao String?
  rpsNumero         String?
  rpsSerie          String?
  status            String    @default("pending")
  xml               String?
  pdfUrl            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client            Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([clientId])
  @@index([idDps])
  @@index([chaveAcesso])
  @@index([numeroNfse])
}

model AdnSyncState {
  cnpj      String   @id
  ultimoNSU BigInt   @default(0)
  updatedAt DateTime @updatedAt
}

model AdnDocument {
  id              String    @id @default(uuid())
  nsu             BigInt    @unique
  chaveAcesso     String?
  tipoDocumento   String?
  tipoEvento      String?
  // Status normalizado da NFSe no nosso domínio: "authorized", "cancelled", "cancelled_substitution", "rejected", "unknown"
  status          String?
  dataHoraGeracao DateTime?
  xmlBase64Gzip   String?
  xmlPlain        String?
  dataEmissao     DateTime?
  competencia     DateTime?
  cnpjPrestador   String?
  prestadorNome   String?
  cnpjTomador     String?
  tomadorNome     String?
  numeroNfse      String?
  valorServicos   Decimal?  @db.Decimal(18, 2)
  valorIss        Decimal?  @db.Decimal(18, 2)
  situacao        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([chaveAcesso])
  @@index([competencia])
  @@index([status])
  @@index([competencia, status, updatedAt])
  @@index([status, updatedAt])
  @@index([dataEmissao, status])
  @@index([cnpjPrestador, dataEmissao])
  @@index([cnpjTomador, dataEmissao])
}

// ==========================
// Portal (modelo novo)
// ==========================

model PortalClient {
  id                 String   @id @default(uuid())
  // Referência opcional para a Company legada (certificado, cadastros, etc.)
  companyId          String?  @unique
  razao              String
  cnpj               String   @unique
  inscricaoMunicipal String?
  uf                 String?
  municipio          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  integrationSettings PortalIntegrationSettings?
  syncState           PortalSyncState?
  invoices            PortalInvoice[]
  guides              Guide[]
  invoiceEvents       PortalInvoiceEvent[]
  syncJobs            PortalInvoiceSyncJob[]
  companyClientUsers  CompanyClientUser[]
  companyFirmAccess   CompanyFirmAccess[]
  taxDocuments        TaxDocument[]

  @@index([cnpj])
  @@index([updatedAt])
}

model Guide {
  id              String    @id @default(uuid())
  portalClientId  String?
  legacyCompanyId String?
  competencia     String? // YYYY-MM
  tipo            String // INSS|FGTS|PIS|COFINS|ISS|SIMPLES|OUTRA
  valor           Decimal?  @db.Decimal(18, 2)
  vencimento      DateTime?
  cnpj            String?

  taxDocuments TaxDocument[]

  source       String  @default("DRIVE") // DRIVE|LOCAL
  sourceFileId String? @unique
  sourcePath   String?

  driveInboxFolderId String?
  driveFinalFolderId String?
  driveFinalFileId   String?

  storageProvider String? // S3|R2|LOCAL
  storageKey      String?
  storageUrl      String?
  hash            String? @unique

  status           String    @default("PENDING") // PENDING|PROCESSING|PROCESSED|NEEDS_REVIEW|ERROR
  errors           Json?
  extracted        Json?
  // Controle de envio por e-mail para guias já processadas
  emailStatus      String? // PENDING|SENDING|SENT|ERROR
  emailAttempts    Int       @default(0)
  emailLastError   String?
  emailSentAt      DateTime?
  emailNextRetryAt DateTime?

  reviewedByUserId String?
  reviewedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portalClient  PortalClient? @relation(fields: [portalClientId], references: [id], onDelete: SetNull)
  legacyCompany Company?      @relation(fields: [legacyCompanyId], references: [id], onDelete: SetNull)

  @@index([portalClientId, competencia, tipo])
  @@index([status])
  @@index([emailStatus, emailNextRetryAt])
  @@index([cnpj, competencia])
}

model GuideIngestionJob {
  id             String    @id @default(uuid())
  source         String    @default("DRIVE")
  sourceFileId   String    @unique
  sourceName     String?
  status         String    @default("PROCESSING") // PROCESSING|DONE|ERROR|SKIPPED
  attempts       Int       @default(1)
  errorReason    String?
  parserPayload  Json?
  createdGuideId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  finishedAt     DateTime?

  @@index([status, updatedAt])
}

model GuideIngestionLock {
  id          String    @id
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt
}

model AppSetting {
  key       String   @id
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyClientUser {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  role      String   @default("CLIENT_USER") // OWNER | CLIENT_ADMIN | CLIENT_USER
  status    String   @default("ACTIVE") // ACTIVE | INVITED | REMOVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company PortalClient @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId, status])
  @@index([companyId, status])
}

model CompanyFirmAccess {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  role      String   @default("STAFF") // FIRM_ADMIN | ACCOUNTANT | STAFF
  status    String   @default("ACTIVE") // ACTIVE | REMOVED
  scopes    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company PortalClient @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId, status])
  @@index([companyId, status])
}

model PortalIntegrationSettings {
  id            String   @id @default(uuid())
  clientId      String   @unique
  provider      String   @default("NFSENACIONAL")
  environment   String   @default("PROD")
  // Certificado é gerenciado na Company (certStorageKey/certPasswordEnc)
  certCompanyId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client PortalClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model PortalSyncState {
  clientId     String    @id
  lastCursor   BigInt    @default(0) // NSU/sequence
  lastSyncAt   DateTime?
  state        String    @default("OK") // OK|RUNNING|ERROR
  lastError    String?
  lockUntil    DateTime?
  backoffUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client PortalClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([lockUntil])
  @@index([backoffUntil])
}

model PortalInvoice {
  id          String  @id @default(uuid())
  clientId    String
  type        String // NFSE, NFE, ...
  numero      String?
  serie       String?
  chaveAcesso String?
  idNfse      String? // opcional (dependendo do provedor)
  idDps       String? // opcional (NFSe Nacional)

  competencia DateTime?
  issueDate   DateTime?
  status      String    @default("PENDENTE") // EMITIDA|CANCELADA|SUBSTITUIDA|REJEITADA|PENDENTE|...
  total       Decimal?  @db.Decimal(18, 2)

  emitenteNome String?
  emitenteDoc  String?
  tomadorNome  String?
  tomadorDoc   String?

  // Storage (por enquanto no DB)
  xmlRaw  String?
  pdfUrl  String?
  xmlHash String?

  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  client PortalClient         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  events PortalInvoiceEvent[]

  @@unique([clientId, chaveAcesso])
  @@unique([clientId, idDps])
  @@unique([clientId, idNfse])
  @@index([clientId])
  @@index([clientId, updatedAt])
  @@index([clientId, competencia, status, updatedAt])
  @@index([clientId, issueDate])
  @@index([status, updatedAt])
}

model PortalInvoiceEvent {
  id         String    @id @default(uuid())
  clientId   String
  invoiceId  String
  type       String
  date       DateTime?
  protocol   String?
  reason     String?
  payloadRaw Json?
  createdAt  DateTime  @default(now())

  client  PortalClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice PortalInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([invoiceId, date])
}

model PortalInvoiceSyncJob {
  id          String   @id @default(uuid())
  clientId    String
  state       String   @default("RUNNING") // RUNNING|DONE|ERROR
  processed   Int      @default(0)
  created     Int      @default(0)
  updated     Int      @default(0)
  duplicates  Int      @default(0)
  errors      Int      @default(0)
  lastCursor  BigInt?
  lastMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client PortalClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([state])
}

model TaxDocument {
  id             String   @id @default(uuid())
  requestId      String?
  portalClientId String?
  guideId        String?
  contentHash    String
  sourceFileName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  portalClient PortalClient?              @relation(fields: [portalClientId], references: [id], onDelete: SetNull)
  guide        Guide?                     @relation(fields: [guideId], references: [id], onDelete: SetNull)
  extractions  TaxDocumentExtraction[]
  logs         TaxDocumentProcessingLog[]

  @@index([contentHash])
  @@index([guideId])
  @@index([requestId])
  @@index([portalClientId])
  @@map("documents")
}

model TaxDocumentExtraction {
  id           String   @id @default(uuid())
  documentId   String
  success      Boolean
  parserSource String?
  documentType String?
  payload      Json?
  confidence   Float?
  warnings     Json?
  rawText      String?  @db.Text
  createdAt    DateTime @default(now())

  document TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_extractions")
}

model TaxDocumentProcessingLog {
  id         String   @id @default(uuid())
  documentId String
  step       String
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())

  document TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_processing_logs")
}
