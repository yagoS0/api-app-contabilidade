{
  "name": "@contabilidade/api",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "start:prod": "npm run prisma:generate && npm run prisma:migrate:deploy && node src/server.js",
    "reset-state": "node -e \"const fs=require('fs'); const paths=['./.state.json','./.processed.json','./state.json','./data/last-run.json','./data/sent-emails.jsonl']; for(const p of paths){ try{ fs.unlinkSync(p);}catch(e){} } console.log('State legado limpo (se existir)');\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrations:audit": "node scripts/validate-migrations.js",
    "prisma:seed": "node prisma/seed.js",
    "portal:migrate": "node scripts/migrate-portal.js",
    "worker:guide-emails": "node src/workers/guideEmailWorker.js",
    "worker:guide-emails:once": "node src/workers/guideEmailWorker.js --once"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@mailchimp/mailchimp_transactional": "^1.0.59",
    "@prisma/client": "^5.22",
    "@xmldom/xmldom": "^0.8.10",
    "archiver": "^7.0.1",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.7.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.3.5",
    "googleapis": "^140.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.14",
    "nodemailer-ses-transport": "^1.5.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "pino": "^8.21.0",
    "xml-crypto": "^3.0.0"
  },
  "devDependencies": {
    "pino-pretty": "^10.3.1",
    "prisma": "^5.22.0"
  }
}
